      "name": "`video",
      "settings": {
        "custom_liquid": "<div class=\"doctor-review-container\">\n  <div class=\"doctor-review-wrapper\">\n    <div class=\"doctor-review-image\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/maxresdefault_1.jpg\" alt=\"Dr Shah\" class=\"review-thumbnail\" onclick=\"openVideoPopup()\">\n      <button class=\"play-button\" onclick=\"openVideoPopup()\">▶</button>\n    </div>\n    <div class=\"doctor-review-text\">\n      <div class=\"review-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/trust.svg\" alt=\"trust icon\" class=\"badge-icon\">\n        TRUSTED AND RECOMMENDED BY LEADING SKINCARE PROFESSIONALS\n      </div>\n      <blockquote class=\"review-quote\">\n        \"<strong>The most advanced LED mask</strong> I’ve tested recently. Just remember — consistency is everything <strong>if you want real results.</strong>\"\n      </blockquote>\n    </div>\n  </div>\n\n  <div id=\"videoPopup\" class=\"popup-overlay\" onclick=\"closeVideoPopup()\">\n    <div class=\"popup-content\" onclick=\"event.stopPropagation()\">\n      <button class=\"close-popup\" onclick=\"closeVideoPopup()\">&times;</button>\n      <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/I2Fe-kP-2Jg\" frameborder=\"0\" allowfullscreen></iframe>\n    </div>\n  </div>\n</div>\n\n<style>\n.doctor-review-container {\n  max-width: 1100px;\n  margin: 0 auto;\n  padding: 16px;\n}\n.doctor-review-wrapper {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 60px;\n  align-items: center;\n  flex-direction: row;\n}\n.doctor-review-image {\n  position: relative;\n  flex: 0 0 auto;\n  width: 100%;\n  max-width: 430px;\n}\n.review-thumbnail {\n  width: 100%;\n  border-radius: 24px;\n  cursor: pointer;\n  height: 400px;\n}\n.play-button {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: white;\n  border: none;\n  font-size: 28px;\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  cursor: pointer;\n  box-shadow: 0 2px 6px rgba(0,0,0,0.2);\n}\n.doctor-review-text {\n  flex: 1;\n  min-width: 250px;\n}\n.review-badge {\n  background: #FFF7F9;\n  padding: 12px 20px;\n  border-radius: 40px;\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 24px;\n  font-size: 14px;\n  font-weight: 600;\n  border: 2px solid #FA9EB2;\n}\n.badge-icon {\n  width: 24px;\n  height: 24px;\n}\n.review-quote {\n  font-size: 28px;\n  line-height: 1.4;\n  font-family: Georgia, serif;\n}\n.popup-overlay {\n  display: none;\n  position: fixed;\n  top: 0; left: 0; right: 0; bottom: 0;\n  background: rgba(0, 0, 0, 0.7);\n  justify-content: center;\n  align-items: center;\n  z-index: 1000;\n}\n.popup-overlay.active {\n  display: flex;\n}\n.popup-content {\n  background: #000;\n  width: 90%;\n  max-width: 800px;\n  aspect-ratio: 16 / 9;\n  position: relative;\n  border-radius: 10px;\n  overflow: hidden;\n}\n.close-popup {\n  position: absolute;\n  top: 8px;\n  right: 12px;\n  background: none;\n  border: none;\n  font-size: 28px;\n  color: white;\n  cursor: pointer;\n}\n\n@media (max-width: 768px) {\n  .doctor-review-wrapper {\n    flex-direction: column-reverse;\n    gap: 24px;\n  }\n  .doctor-review-image {\n    max-width: 100%;\n  }\n}\n@media (max-width: 768px) {\n  .doctor-review-wrapper {\n    flex-direction: column;\n    gap: 24px;\n  }\n.review-thumbnail {\n  height: auto;\n}\n</style>\n\n<script>\nfunction openVideoPopup() {\n  document.getElementById(\"videoPopup\").classList.add(\"active\");\n}\nfunction closeVideoPopup() {\n  document.getElementById(\"videoPopup\").classList.remove(\"active\");\n}\n</script>",
