        "custom_liquid": "{% if request.path == '/products/lunara-light-mask-portable' %}\n  <style>\n    .comparison-wrapper {\n      max-width: 1000px;\n      margin: 0 auto;\n    }\n\n    .comparison-header,\n    .comparison-row {\n      display: flex;\n      width: 100%;\n      border-top: 1px solid #f0d4dc;\n    }\n\n    .comparison-col {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 16px;\n      font-size: 14px;\n    }\n\n    .comparison-col.feature {\n      justify-content: flex-start;\n      font-weight: 500;\n      text-align: left;\n      width: 50%;\n    }\n\n    .comparison-col.lunaskin {\n      width: 25%;\n      background-color: #FFDDE6;\n    }\n\n    .comparison-col.other {\n      width: 25%;\n    }\n\n    .comparison-col.header {\n      border-top: none;\n    }\n\n    .comparison-col.empty {\n      visibility: hidden;\n      height: 100px;\n    }\n\n    .comparison-col img.mask-image {\n      min-height: 100px;\n      height: auto;\n      max-height: 140px;\n    }\n\n    .comparison-col.lunaskin img.icon,\n    .comparison-col.other img.icon {\n      height: 20px;\n    }\n\n    @media screen and (max-width: 768px) {\n      .comparison-col.feature {\n        font-size: 13px;\n      }\n\n      .comparison-col img.mask-image {\n        min-height: auto;\n        max-height: 100px;\n      }\n\n      .comparison-col.lunaskin img.icon,\n      .comparison-col.other img.icon {\n        height: 18px;\n      }\n    }\n  </style>\n\n  <div style=\"padding: 40px 20px; background-color: #fff;\">\n    <h2 style=\"text-align: center; font-size: 24px; font-weight: 600; margin-bottom: 40px;\">\n      Not Just Another LED Mask\n    </h2>\n\n    <div class=\"comparison-wrapper\">\n      <!-- Header row -->\n      <div class=\"comparison-header\">\n        <div class=\"comparison-col feature\">\n          <div class=\"comparison-col empty\"></div>\n        </div>\n        <div class=\"comparison-col lunaskin header\">\n          <img class=\"mask-image\" src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/sky_mask.png\" alt=\"Lunaskin Mask\">\n        </div>\n        <div class=\"comparison-col other header\">\n          <img class=\"mask-image\" src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/Another_mask.png?v=1749057464\" alt=\"Other Mask\">\n        </div>\n      </div>\n\n      <!-- Comparison rows -->\n      {% assign features = \"Anatomical design,7 LED Colours,240 Medical-Grade LEDs,Waterproof Design,Eye Protection,Food-Grade Silicone,Affordable Cost\" | split: \",\" %}\n      {% assign lunaskin_icons = \"Check.svg,Check.svg,Check.svg,Check.svg,Check.svg,Check.svg,Check.svg\" | split: \",\" %}\n      {% assign others_icons = \"Cross.svg,Cross.svg,Cross.svg,Cross.svg,Cross.svg,Cross.svg,Check.svg\" | split: \",\" %}\n\n      {% for feature in features %}\n        <div class=\"comparison-row\">\n          <div class=\"comparison-col feature\">\n            {{ feature }}\n          </div>\n          <div class=\"comparison-col lunaskin\">\n            <img class=\"icon\" src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/{{ lunaskin_icons[forloop.index0] | strip }}\" alt=\"icon\">\n          </div>\n          <div class=\"comparison-col other\">\n            <img class=\"icon\" src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/{{ others_icons[forloop.index0] | strip }}\" alt=\"icon\">\n          </div>\n        </div>\n      {% endfor %}\n    </div>\n  </div>\n{% endif %}",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
