    "custom_liquid_3Y7yVC": {
      "type": "custom-liquid",
      "name": "sales pop-up",
      "settings": {
        "custom_liquid": "<!-- Add to theme.liquid before </body> -->\n<style>\n  .email-popup-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(0,0,0,0.5);\n    display: none;\n    z-index: 9999;\n  }\n\n  .email-popup {\n    position: fixed;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 400px;\n    max-width: 90%;\n    background: #fff;\n    padding: 30px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.3);\n    text-align: center;\n    border-radius: 16px;\n    border: 1px solid #FA9EB2;\n  }\n\n  .email-popup-close {\n    position: absolute;\n    top: 10px;\n    right: 15px;\n    font-size: 14px;\n    cursor: pointer;\n    font-weight: 400;\n  }\n\n  .email-popup input[type=\"email\"] {\n    width: 100%;\n    padding: 12px;\n    margin: 20px 0 10px;\n    font-size: 16px;\n    border: 1px solid #FA9EB2;\n    border-radius: 6px;\n  }\n\n  .email-popup button {\n    width: 100%;\n    padding: 12px;\n    background: #FA9EB2;\n    color: #fff;\n    border: none;\n    font-size: 14px;\n    cursor: pointer;\n    border-radius: 6px;\n  }\n\n  .email-popup .checkbox-wrapper {\n    margin-top: 15px;\n    text-align: left;\n    font-size: 13px;\n  }\n\n  .email-popup .checkbox-wrapper input {\n    margin-right: 8px;\n  }\n.title3{\ncolor: #FA9EB2;\nfont-weight: 600;\n}\n</style>\n\n<div id=\"emailPopupOverlay\" class=\"email-popup-overlay\">\n  <div class=\"email-popup\">\n    <div class=\"email-popup-close\" id=\"closePopup\">× CLOSE</div>\n    <h3 class=\"title3\">Limited Time\n10% off</h3>\n    <p>Save on your first order and get email only offers when you join.</p>\n\n    {% form 'customer', id: 'popupNewsletterForm' %}\n      <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n      <input type=\"email\" id=\"popupEmail\" name=\"contact[email]\" placeholder=\"EMAIL\" required>\n      <button type=\"submit\" id=\"popupSubmit\">SIGN IN</button>\n      <div class=\"checkbox-wrapper\">\n        <label><input type=\"checkbox\" id=\"popupAgree\"> By clicking here, I agree to privacy policy and terms of use.</label>\n      </div>\n    {% endform %}\n\n  </div>\n</div>\n\n<script>\n  function validateEmail(email) {\n    return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n  }\n\n  window.addEventListener('load', function () {\n    if (!localStorage.getItem('popupClosed')) {\n      setTimeout(() => {\n        document.getElementById('emailPopupOverlay').style.display = 'block';\n      }, 5000);\n    }\n  });\n\n  document.getElementById('closePopup').addEventListener('click', function () {\n    document.getElementById('emailPopupOverlay').style.display = 'none';\n    localStorage.setItem('popupClosed', 'true');\n  });\n\n  document.getElementById('emailPopupOverlay').addEventListener('click', function (e) {\n    if (e.target.id === 'emailPopupOverlay') {\n      this.style.display = 'none';\n      localStorage.setItem('popupClosed', 'true');\n    }\n  });\n\n  document.getElementById('popupNewsletterForm').addEventListener('submit', function (e) {\n    const email = document.getElementById('popupEmail').value;\n    const agreed = document.getElementById('popupAgree').checked;\n\n    if (!validateEmail(email)) {\n      e.preventDefault();\n      alert(\"Please enter a valid email address.\");\n      return;\n    }\n\n    if (!agreed) {\n      e.preventDefault();\n      alert(\"You must agree to the privacy policy and terms of use.\");\n      return;\n    }\n\n    localStorage.setItem('popupClosed', 'true');\n  });\n</script>",
