    "custom_liquid_jwAVFn": {
      "type": "custom-liquid",
      "name": "companies logo block",
      "settings": {
        "custom_liquid": "<style>\n  @media screen and (min-width: 769px) {\n    .logos-row {\n      justify-content: center !important;\n    }\n  }\n</style>\n\n<div style=\"background-color: #FFDCE5; padding: 40px 0;\">\n  <div class=\"logos-row\" style=\"\n    display: flex;\n    overflow-x: auto;\n    gap: 60px;\n    padding: 0 40px;\n    scroll-padding-left: 40px;\n    -webkit-overflow-scrolling: touch;\n  \">\n\n    {% assign logos = \n      \"allure.webp,\n      marie_daire.webp,\n      vogue.webp,\n      elle.webp\" | split: \",\" %}\n\n    {% for logo in logos %}\n      <div style=\"\n        flex: 0 0 auto;\n        width: 240px;\n        text-align: center;\n        scroll-snap-align: start;\n      \">\n        <div style=\"\n          width: 100%;\n          height: 0;\n          padding-top: 35%;\n          position: relative;\n        \">\n          <img \n            src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/{{ logo | strip }}\" \n            alt=\"logo\" \n            style=\"\n              position: absolute;\n              top: 0;\n              left: 0;\n              width: 100%;\n              height: 100%;\n              object-fit: cover;\n            \" \n          />\n        </div>\n        <p style=\"font-size: 12px; line-height: 1.5; color: #000; margin-top: 0px; font-weight: 300;\">\n          {{ texts[forloop.index0] | strip }}\n        </p>\n      </div>\n    {% endfor %}\n  </div>\n</div>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_tmEWzY": {
      "type": "custom-liquid",
      "name": "steps",
      "settings": {
        "custom_liquid": "{% if request.path == '/products/7-led-lifting-and-firming-facial-device' %}\n  <style>\n    .step-scroll {\n      display: flex;\n      gap: 60px;\n      overflow-x: auto;\n      scroll-snap-type: x mandatory;\n      -webkit-overflow-scrolling: touch;\n      padding-bottom: 10px;\n      scroll-padding-left: 20px;\n    }\n\n    .step-item {\n      flex: 0 0 auto;\n      width: 100%;\n      max-width: 380px;\n      scroll-snap-align: start;\n      text-align: center;\n    }\n\n    .step-image {\n      width: 100%;\n      height: 380px;\n      border-radius: 20px;\n      overflow: hidden;\n      background-color: #f0f0f0;\n      margin: 0 auto 20px;\n    }\n\n    .step-image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .step-title {\n      font-size: 18px;\n      font-weight: 700;\n      margin-bottom: 10px;\n    }\n\n    .step-text {\n      font-size: 14px;\n      line-height: 1.6;\n      color: #333;\n    }\n\n    /* Центрування на desktop */\n    @media screen and (min-width: 769px) {\n      .step-scroll {\n        justify-content: center;\n        overflow-x: visible;\n      }\n    }\n  </style>\n\n  <div style=\"padding: 60px 20px; background-color: #fff; text-align: center;\">\n    <h2 style=\"font-size: 26px; font-weight: 600; margin-bottom: 40px;\">\n      <span style=\"color: #EC5F94; font-style: italic;\">See results</span> in 3 simple steps\n    </h2>\n\n    <div class=\"step-scroll\">\n      <!-- Step 1 -->\n      <div class=\"step-item\">\n        <div class=\"step-image\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/step-1.webp\" alt=\"Step 1 Image\">\n        </div>\n        <h3 class=\"step-title\">Step 1: Prep Your Skin</h3>\n        <p class=\"step-text\">\n          Start with a clean face. Gently cleanse your skin and apply your favorite anti-aging serum we recommend pairing with our Hydrating Renewal Serum for optimal results, but you're welcome to use your own.\n        </p>\n      </div>\n\n      <!-- Step 2 -->\n      <div class=\"step-item\">\n        <div class=\"step-image\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/step-2.webp\" alt=\"Step 2 Image\">\n        </div>\n        <h3 class=\"step-title\">Step 2: Activate & Customize</h3>\n        <p class=\"step-text\">\n          Hold the power button for 10 seconds until you hear a gentle hum this means your device is activated and ready. Select your preferred LED light therapy mode based on your skin goals: Red for anti-aging, green for fine lines & texture or all colors. Your personalized treatment awaits.\n        </p>\n      </div>\n\n      <!-- Step 3 -->\n      <div class=\"step-item\">\n        <div class=\"step-image\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/step-3.webp\" alt=\"Step 3 Image\">\n        </div>\n        <h3 class=\"step-title\">Step 3: Glide & Glow</h3>\n        <p class=\"step-text\">\n          Slowly glide the LunaraLight across your face, jawline, and neck using gentle upward strokes. Let the EMS microcurrent and LED light therapy do the work lifting, toning and transforming your skin with every pass. Congrats you’re officially on your way to firmer, sculpted, radiant skin!\n        </p>\n      </div>\n    </div>\n  </div>\n{% endif %}",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
