          "settings": {
            "custom_liquid": "<style>\n@media (max-width: 767px){\n  .sticky-atc{\n    position: fixed;\n    left: 0; right: 0; bottom: 0;\n    display: none;\n    z-index: 9999;\n    background: var(--color-background, #fff);\n    box-shadow: 0 -4px 12px rgba(0,0,0,.1);\n    padding-bottom: env(safe-area-inset-bottom);\n  }\n  .sticky-atc .sticky-atc__btn{\n    width: 101% !important;\n    min-height: 56px !important;\n    font-size: 18px !important;\n    border-radius: 0 !important;\n    background-color: #f8adbe !important;\n    border-color: #f8adbe !important;\n    margin-bottom: -4px;\n    color: #fff !important;\n    font-weight: 600 !important;\n    text-transform: uppercase !important;\n  }\n  body.has-sticky-atc{\n    padding-bottom: calc(var(--sticky-atc-h, 56px) + env(safe-area-inset-bottom));\n  }\n}\n</style>\n\n<script>\n(function(){\n  var mq = window.matchMedia('(max-width: 767px)');\n  var SEL_BTN = 'form[action*=\"/cart/add\"] .product-form__submit, button[name=\"add\"].product-form__submit';\n  var stickyWrap, stickyBtn, origBtn, origForm, io, mo;\n\n  function getOrig(){\n    var b = document.querySelector(SEL_BTN);\n    if (!b) return null;\n    origForm = b.closest('form');\n    return b;\n  }\n\n  function ensureSticky(){\n    if (stickyWrap) return;\n    stickyWrap = document.createElement('div');\n    stickyWrap.className = 'sticky-atc';\n    stickyBtn = document.createElement('button');\n    stickyBtn.type = 'button';\n    stickyBtn.className = 'product-form__submit sticky-atc__btn';\n    stickyWrap.appendChild(stickyBtn);\n    document.body.appendChild(stickyWrap);\n  }\n\n  function syncClone(){\n    if (!origBtn || !stickyBtn) return;\n    stickyBtn.disabled = !!origBtn.disabled;\n    stickyBtn.innerHTML = origBtn.innerHTML;\n  }\n\n  function showSticky(show){\n    if (!stickyWrap) return;\n    stickyWrap.style.display = show ? 'block' : 'none';\n    document.body.classList.toggle('has-sticky-atc', !!show);\n    if (show){\n      requestAnimationFrame(function(){\n        document.documentElement.style.setProperty('--sticky-atc-h', stickyWrap.offsetHeight + 'px');\n      });\n    }\n  }\n\n  function onClickClone(e){\n    e.preventDefault();\n    if (!origBtn || !origForm || origBtn.disabled) return;\n    // Викликаємо нативний клік по оригінальній кнопці\n    origBtn.dispatchEvent(new MouseEvent('click', { bubbles: true }));\n  }\n\n  function observeVisibility(){\n    if (io) { io.disconnect(); io = null; }\n    if (!origBtn) { showSticky(false); return; }\n    io = new IntersectionObserver(function(entries){\n      var entry = entries[0];\n      var visible = entry && entry.isIntersecting && entry.intersectionRatio > 0;\n      showSticky(!visible && mq.matches);\n    }, { threshold: [0, 0.01, 1] });\n    io.observe(origBtn);\n  }\n\n  function observeMutations(){\n    if (mo) { mo.disconnect(); mo = null; }\n    if (!origBtn) return;\n    mo = new MutationObserver(syncClone);\n    mo.observe(origBtn, { attributes:true, childList:true, characterData:true, subtree:true });\n  }\n\n  function mount(){\n    if (!mq.matches) { teardown(); return; }\n    origBtn = getOrig();\n    if (!origBtn) { teardown(); return; }\n    ensureSticky();\n    syncClone();\n    observeVisibility();\n    observeMutations();\n    stickyBtn.removeEventListener('click', onClickClone);\n    stickyBtn.addEventListener('click', onClickClone, { passive:false });\n  }\n\n  function teardown(){\n    showSticky(false);\n    if (io) { io.disconnect(); io = null; }\n    if (mo) { mo.disconnect(); mo = null; }\n  }\n\n  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', mount);\n  else mount();\n\n  var pageMO = new MutationObserver(function(){\n    var current = document.querySelector(SEL_BTN);\n    if (current !== origBtn) mount();\n  });\n  pageMO.observe(document.body, { childList:true, subtree:true });\n\n  if (mq.addEventListener) mq.addEventListener('change', mount);\n  else mq.addListener(mount);\n\n  window.addEventListener('resize', function(){\n    if (document.body.classList.contains('has-sticky-atc')) {\n      document.documentElement.style.setProperty('--sticky-atc-h', stickyWrap.offsetHeight + 'px');\n    }\n  }, { passive:true });\n})();\n</script>"
          }
