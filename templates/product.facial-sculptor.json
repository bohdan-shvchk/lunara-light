    "custom_liquid_TjtkNz": {
      "type": "custom-liquid",
      "name": "reviews-face-device",
      "settings": {
        "custom_liquid": "{% if product.handle == '7-led-lifting-and-firming-facial-device' or product.handle == '7-led-lifting-and-firming-neck-massager-travel-case' %}\n  <div class=\"masonry-container\">\n    <div class=\"masonry-col col-1\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-01.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-05.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-09.png\" alt=\"\">\n    </div>\n    <div class=\"masonry-col col-2\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-02.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-06.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-10.png\" alt=\"\">\n    </div>\n    <div class=\"masonry-col col-3 mobile-hide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-03.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-07.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-11.png\" alt=\"\">\n    </div>\n    <div class=\"masonry-col col-4 mobile-hide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-04.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-08.png\" alt=\"\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0951/2766/7027/files/review-neck-12.png\" alt=\"\">\n    </div>\n  </div>\n\n  <style>\n    .masonry-container {\n      display: flex;\n      justify-content: center;\n      max-width: 1100px;\n      margin: 0 auto;\n      gap: 16px;\n      flex-wrap: wrap;\n    }\n    .masonry-col {\n      display: flex;\n      flex-direction: column;\n      gap: 16px;\n      flex: 1;\n    }\n    .masonry-col img {\n      width: 100%;\n      height: auto;\n      display: block;\n    }\n    @media (max-width: 767px) {\n      .mobile-hide {\n        display: none;\n      }\n      .masonry-container {\n        padding-left: 16px;\n        padding-right: 16px;\n        gap: 16px;\n      }\n      .col-1, .col-2 {\n        width: calc(50% - 8px);\n      }\n    }\n  </style>\n{% endif %}",
