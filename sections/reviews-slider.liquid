<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
{{ 'reviews-slider.css' | asset_url | stylesheet_tag }}

<div class="reviews-slider-section" style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <h2 class="title inline-richtext {{ section.settings.heading_size }} reviews-slider__heading"{% if section.settings.heading_font_size > 0 %} style="font-size: {{ section.settings.heading_font_size }}px;"{% endif %}>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="swiper reviews-slider-swiper">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="review-card" style="border-color: {{ section.settings.card_border_color }}; border-radius: {{ section.settings.card_radius }}px;">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | default: 'review photo' }}"
                class="review-photo"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {%- endif -%}
            <div class="review-stars">
              {%- assign stars = block.settings.stars -%}
              {%- for i in (1..stars) -%}⭐{%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h4 class="review-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="review-text">{{ block.settings.text }}</p>
            {%- endif -%}
            <div class="review-author">
              {%- if block.settings.author != blank -%}
                <span class="author-name">{{ block.settings.author }}</span>
              {%- endif -%}
              {%- if block.settings.verified -%}
                <span class="verified-badge">✅ Verified customer</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="swiper-button-prev custom-swiper-button">
      {%- if section.settings.arrow_prev != blank -%}
        <img class="arrow-icon" src="{{ section.settings.arrow_prev | image_url: width: 48 }}" alt="prev" width="32" height="32">
      {%- else -%}
        <img class="arrow-icon" src="https://cdn.shopify.com/s/files/1/0951/2766/7027/files/Arrow-left.png" alt="prev" width="32" height="32">
      {%- endif -%}
    </div>
    <div class="swiper-button-next custom-swiper-button">
      {%- if section.settings.arrow_next != blank -%}
        <img class="arrow-icon" src="{{ section.settings.arrow_next | image_url: width: 48 }}" alt="next" width="32" height="32">
      {%- else -%}
        <img class="arrow-icon" src="https://cdn.shopify.com/s/files/1/0951/2766/7027/files/Arrow-right.png" alt="next" width="32" height="32">
      {%- endif -%}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function() {
    function initSwiper() {
      var el = document.querySelector('.reviews-slider-swiper');
      if (!el) return;
      if (el.swiper) el.swiper.destroy(true, true);
      new Swiper(el, {
        slidesPerView: 1,
        spaceBetween: 20,
        loop: true,
        navigation: {
          nextEl: el.querySelector('.swiper-button-next'),
          prevEl: el.querySelector('.swiper-button-prev')
        },
        pagination: {
          el: el.querySelector('.swiper-pagination'),
          clickable: true
        },
        breakpoints: {
          580: { slidesPerView: 2, spaceBetween: 20 },
          900: { slidesPerView: {{ section.settings.slides_desktop }}, spaceBetween: 24 }
        }
      });
    }
    document.addEventListener('DOMContentLoaded', initSwiper);
    document.addEventListener('shopify:section:load', initSwiper);
    document.addEventListener('shopify:block:select', initSwiper);
  })();
</script>

{% schema %}
{
  "name": "Reviews Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading font size (overrides size above, 0 = auto)",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#ffdbe5"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides per view (desktop)",
      "default": 3
    },
    {
      "type": "image_picker",
      "id": "arrow_prev",
      "label": "Previous arrow image"
    },
    {
      "type": "image_picker",
      "id": "arrow_next",
      "label": "Next arrow image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "🇺🇸 — Jessica M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Slider",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
