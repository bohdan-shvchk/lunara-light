<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
{{ 'reviews-slider.css' | asset_url | stylesheet_tag }}

<div class="reviews-slider-section" style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <h2 class="reviews-slider__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="swiper reviews-slider-swiper">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="review-card" style="border-color: {{ section.settings.card_border_color }}; border-radius: {{ section.settings.card_radius }}px;">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | default: 'review photo' }}"
                class="review-photo"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {%- endif -%}
            <div class="review-stars">
              {%- assign stars = block.settings.stars -%}
              {%- for i in (1..stars) -%}⭐{%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h4 class="review-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="review-text">{{ block.settings.text }}</p>
            {%- endif -%}
            <div class="review-author">
              {%- if block.settings.author != blank -%}
                <span class="author-name">{{ block.settings.author }}</span>
              {%- endif -%}
              {%- if block.settings.verified -%}
                <span class="verified-badge">✅ Verified customer</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="swiper-button-prev custom-swiper-button">
      {%- if section.settings.arrow_prev != blank -%}
        <img src="{{ section.settings.arrow_prev | image_url: width: 48 }}" alt="prev" width="24">
      {%- else -%}
        ‹
      {%- endif -%}
    </div>
    <div class="swiper-button-next custom-swiper-button">
      {%- if section.settings.arrow_next != blank -%}
        <img src="{{ section.settings.arrow_next | image_url: width: 48 }}" alt="next" width="24">
      {%- else -%}
        ›
      {%- endif -%}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.reviews-slider-swiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      navigation: {
        nextEl: '.reviews-slider-swiper .swiper-button-next',
        prevEl: '.reviews-slider-swiper .swiper-button-prev'
      },
      pagination: {
        el: '.reviews-slider-swiper .swiper-pagination',
        clickable: true
      },
      breakpoints: {
        480: { slidesPerView: 2 },
        768: { slidesPerView: {{ section.settings.slides_desktop }} }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Reviews Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#ffdbe5"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides per view (desktop)",
      "default": 3
    },
    {
      "type": "image_picker",
      "id": "arrow_prev",
      "label": "Previous arrow image"
    },
    {
      "type": "image_picker",
      "id": "arrow_next",
      "label": "Next arrow image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "🇺🇸 — Jessica M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Slider",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
