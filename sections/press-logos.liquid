{{ 'press-logos.css' | asset_url | stylesheet_tag }}

<div class="press-logos color-{{ section.settings.color_scheme }}" style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <h2 class="title inline-richtext {{ section.settings.heading_size }} press-logos__heading"{% if section.settings.heading_font_size > 0 %} style="font-size: {{ section.settings.heading_font_size }}px;"{% endif %}>{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="press-logos__row">
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
        <div class="press-logos__item" {{ block.shopify_attributes }}>
          <div class="press-logos__img-wrap">
            <img
              src="{{ block.settings.image | image_url: width: 480 }}"
              alt="{{ block.settings.image.alt | default: 'logo' }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          </div>
          {%- if block.settings.text != blank -%}
            <p class="press-logos__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Press Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "As seen in"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading font size (overrides size above, 0 = auto)",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFDCE5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text below logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
