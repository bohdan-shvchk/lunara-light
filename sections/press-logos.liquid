{{ 'press-logos.css' | asset_url | stylesheet_tag }}

<div class="press-logos color-{{ section.settings.color_scheme }}" style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <p class="press-logos__heading">{{ section.settings.heading }}</p>
  {%- endif -%}
  <div class="press-logos__row">
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
        <div class="press-logos__item" {{ block.shopify_attributes }}>
          <div class="press-logos__img-wrap">
            <img
              src="{{ block.settings.image | image_url: width: 480 }}"
              alt="{{ block.settings.image.alt | default: 'logo' }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          </div>
          {%- if block.settings.text != blank -%}
            <p class="press-logos__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Press Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As seen in"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFDCE5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text below logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
